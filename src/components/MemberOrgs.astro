---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const orgs = [
  {
    id: 'EDS',
    name: 'Estrellas del Sur',
    location: 'Córdoba, Andalucía',
    color: '#c44e2a',
    flag: '🌟',
    description: 'Asociación juvenil cordobesa promotora de la movilidad Erasmus+ y el aprendizaje no formal. Sede fundadora de la federación.',
    tags: ['Intercambios juveniles', 'Voluntariado ESC', 'Formación'],
    website: 'https://estrellasdelsur.eu',
  },
  {
    id: 'EMA',
    name: 'Estrella Magec',
    location: 'Islas Canarias',
    color: '#d9a727',
    flag: '🌺',
    description: 'Asociación canaria dedicada a la inclusión juvenil y la participación activa en proyectos europeos de educación no formal.',
    tags: ['Inclusión juvenil', 'Erasmus+', 'Educación no formal'],
    website: null,
  },
  {
    id: 'MUR',
    name: 'Murcia Debate',
    location: 'Murcia',
    color: '#6b3a8a',
    flag: '🎤',
    description: 'Organización murciana que impulsa el pensamiento crítico y la participación juvenil a través del debate y proyectos europeos.',
    tags: ['Debate', 'Pensamiento crítico', 'Participación juvenil'],
    website: null,
  },
];
---

<section class="section member-orgs" id="organizaciones">
  <div class="container">
    <div class="orgs-header fade-in">
      <span class="section-label">Nuestras organizaciones</span>
      <h2 class="section-title">Tres asociaciones, un mismo compromiso</h2>
      <p class="section-subtitle">
        Entidades de distintas regiones de España que comparten la visión de una Europa
        más accesible y participativa para la juventud.
      </p>
    </div>

    <div class="orgs-grid">
      {orgs.map((org, i) => (
        <article class={`org-card fade-in fade-in-delay-${i + 1}`} style={`--c: ${org.color}`}>
          <div class="org-top">
            <span class="org-flag">{org.flag}</span>
            <span class="org-id">{org.id}</span>
          </div>
          <div class="org-body">
            <h3>{org.name}</h3>
            <p class="org-loc">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
              {org.location}
            </p>
            <p class="org-desc">{org.description}</p>
            <div class="org-tags">
              {org.tags.map(t => <span class="org-tag">{t}</span>)}
            </div>
          </div>
          <div class="org-foot">
            {org.website
              ? <a href={org.website} target="_blank" rel="noopener" class="org-link">Visitar web ↗</a>
              : <span class="org-soon">Próximamente online</span>
            }
          </div>
        </article>
      ))}
    </div>

    <div class="orgs-cta fade-in">
      <a href={`${base}/organizaciones/`} class="btn btn-outline">
        Ver todas las organizaciones
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
.member-orgs { background: var(--sand); }
.orgs-header { max-width: 560px; margin-bottom: 3rem; }
.orgs-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1.75rem; margin-bottom: 2.5rem;
}
.org-card {
  background: var(--parchment);
  border-radius: var(--radius-lg);
  border: 1px solid rgba(42,31,14,.07);
  box-shadow: var(--shadow-card);
  overflow: hidden; display: flex; flex-direction: column;
  transition: transform .25s ease, box-shadow .25s ease;
}
.org-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }
.org-top {
  background: color-mix(in srgb, var(--c) 10%, var(--sand));
  border-bottom: 3px solid var(--c);
  padding: 1.75rem 1.5rem 1.25rem;
  display: flex; align-items: flex-start; justify-content: space-between;
}
.org-flag { font-size: 2.4rem; }
.org-id {
  font-size: .68rem; font-weight: 700; letter-spacing: .12em;
  padding: .25rem .65rem; border-radius: var(--radius-full);
  background: var(--c); color: #fff;
}
.org-body { padding: 1.25rem 1.5rem; flex: 1; }
.org-body h3 { font-size: 1.2rem; color: var(--ink); margin-bottom: .35rem; }
.org-loc {
  display: flex; align-items: center; gap: .3rem;
  font-size: .8rem; color: var(--ink-mute); margin-bottom: .9rem;
}
.org-desc { font-size: .88rem; color: var(--ink-soft); line-height: 1.65; margin-bottom: 1rem; }
.org-tags { display: flex; flex-wrap: wrap; gap: .4rem; }
.org-tag {
  font-size: .71rem; font-weight: 500;
  padding: .2rem .7rem; border-radius: var(--radius-full);
  background: color-mix(in srgb, var(--c) 10%, white);
  color: color-mix(in srgb, var(--c) 80%, black);
  border: 1px solid color-mix(in srgb, var(--c) 25%, transparent);
}
.org-foot {
  padding: .9rem 1.5rem;
  border-top: 1px solid var(--sand-dark);
}
.org-link {
  font-size: .88rem; font-weight: 500; color: var(--c);
  text-decoration: none; transition: gap .2s;
  display: inline-flex; align-items: center; gap: .3rem;
}
.org-link:hover { text-decoration: underline; }
.org-soon { font-size: .82rem; color: var(--ink-mute); font-style: italic; }
.orgs-cta { text-align: center; }

@media (max-width: 900px) { .orgs-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 580px) { .orgs-grid { grid-template-columns: 1fr; } }
</style>

---
const proyectos = [
  {
    id: 'ka153',
    badge: 'Erasmus+ KA153',
    badgeColor: '#003399',
    title: 'Movilidad de Trabajadores de Juventud',
    org: 'Federación Estrellas de Europa',
    status: 'Activo',
    statusColor: '#3d7848',
    description: 'Subvención Erasmus+ KA153 concedida a la federación para financiar estancias formativas de nuestros educadores y técnicos de juventud en organizaciones europeas. Una oportunidad única para elevar la calidad de nuestros proyectos.',
    tags: ['Movilidad internacional', 'Formación', 'Trabajadores de juventud'],
    icon: '🏆',
    highlight: true,
  },
  {
    id: 'nest',
    badge: 'Proyecto europeo',
    badgeColor: '#6b3a8a',
    title: 'NEST',
    org: 'Red de socios europeos',
    status: 'En desarrollo',
    statusColor: '#d9a727',
    description: 'Proyecto de cooperación internacional en el que Estrellas de Europa participa junto a socios de distintos países europeos. Centrado en la educación no formal, la participación juvenil y el intercambio de metodologías innovadoras.',
    tags: ['Cooperación internacional', 'Educación no formal', 'Innovación'],
    icon: '🌐',
    highlight: false,
  },
];
---

<section class="section proyectos-section" id="proyectos">
  <div class="container">
    <div class="proyectos-header fade-in">
      <span class="section-label">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Proyectos activos
      </span>
      <h2 class="section-title">Lo que estamos construyendo</h2>
      <p class="section-subtitle">
        Proyectos con impacto real para jóvenes y educadores de toda España.
      </p>
    </div>

    <div class="proyectos-grid">
      {proyectos.map((p, i) => (
        <article class={`proyecto-card fade-in fade-in-delay-${i + 1} ${p.highlight ? 'proyecto-highlight' : ''}`}>
          <div class="proyecto-top">
            <div class="proyecto-icon">{p.icon}</div>
            <div class="proyecto-meta">
              <span class="proyecto-badge" style={`background: ${p.badgeColor}18; color: ${p.badgeColor}; border-color: ${p.badgeColor}30`}>
                {p.badge}
              </span>
              <span class="proyecto-status" style={`color: ${p.statusColor}`}>
                <span class="status-dot" style={`background: ${p.statusColor}`}></span>
                {p.status}
              </span>
            </div>
          </div>

          <h3 class="proyecto-title">{p.title}</h3>
          <p class="proyecto-org">{p.org}</p>
          <p class="proyecto-desc">{p.description}</p>

          <div class="proyecto-tags">
            {p.tags.map(t => <span class="proyecto-tag">{t}</span>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.proyectos-section { background: var(--sand); }
.proyectos-header { margin-bottom: 3rem; }
.proyectos-grid {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 1.75rem;
}

.proyecto-card {
  background: var(--parchment);
  border-radius: var(--radius-lg);
  border: 1px solid rgba(42,31,14,.07);
  box-shadow: var(--shadow-card);
  padding: 2rem;
  display: flex; flex-direction: column; gap: 1rem;
  transition: transform .25s ease, box-shadow .25s ease;
}
.proyecto-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }

.proyecto-highlight {
  border-color: rgba(0,51,153,.15);
  background: linear-gradient(135deg, #fdf9f3 0%, #f0f4ff 100%);
  box-shadow: var(--shadow-card), 0 0 0 1px rgba(0,51,153,.08);
}

.proyecto-top {
  display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem;
}
.proyecto-icon { font-size: 2.2rem; line-height: 1; }
.proyecto-meta { display: flex; flex-direction: column; align-items: flex-end; gap: .4rem; }

.proyecto-badge {
  font-size: .72rem; font-weight: 600; letter-spacing: .06em;
  text-transform: uppercase; padding: .25rem .7rem;
  border-radius: var(--radius-full); border: 1px solid;
  white-space: nowrap;
}
.proyecto-status {
  display: flex; align-items: center; gap: .35rem;
  font-size: .78rem; font-weight: 500;
}
.status-dot {
  width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
}

.proyecto-title {
  font-size: 1.25rem; color: var(--ink); line-height: 1.3;
  font-family: 'Playfair Display', Georgia, serif;
}
.proyecto-org {
  font-size: .8rem; font-weight: 500; color: var(--ink-mute);
  text-transform: uppercase; letter-spacing: .06em;
}
.proyecto-desc {
  font-size: .9rem; color: var(--ink-soft); line-height: 1.7;
  flex: 1;
}
.proyecto-tags {
  display: flex; flex-wrap: wrap; gap: .4rem; margin-top: .25rem;
}
.proyecto-tag {
  font-size: .72rem; font-weight: 500;
  padding: .2rem .65rem; border-radius: var(--radius-full);
  background: var(--sand); color: var(--ink-soft);
  border: 1px solid var(--sand-dark);
}

@media (max-width: 720px) { .proyectos-grid { grid-template-columns: 1fr; } }
</style>

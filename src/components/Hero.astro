---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="hero">
  <!-- Mapa de Europa decorativo -->
  <div class="hero-bg-pattern" aria-hidden="true"></div>

  <!-- Logo grande en el fondo -->
  <div class="hero-logo-bg" aria-hidden="true">
    <img src={`${base}/logo.jpg`} alt="" />
  </div>

  <div class="container hero-inner">
    <div class="hero-text fade-in">
      <div class="hero-kicker">
        <span class="kicker-dot" style="background:var(--c-sur)"></span>
        <span class="kicker-dot" style="background:var(--c-magec)"></span>
        <span class="kicker-dot" style="background:var(--c-green)"></span>
        <span class="kicker-dot" style="background:var(--c-murcia)"></span>
        <span class="kicker-dot" style="background:var(--c-blue)"></span>
        <span class="kicker-label">Federación · Erasmus+ · España</span>
      </div>

      <h1>
        Juntos llegamos<br />
        <em>más lejos</em>
      </h1>

      <p class="hero-lead">
        Estrellas de Europa une asociaciones juveniles de distintas regiones de España
        para impulsar proyectos europeos con mayor alcance e impacto.
      </p>

      <div class="hero-actions">
        <a href={`${base}/organizaciones/`} class="btn btn-amber btn-lg">
          Nuestras organizaciones
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={`${base}/sobre-nosotros/`} class="btn btn-outline-white btn-lg">
          Conocer la federación
        </a>
      </div>

      <div class="hero-orgs">
        <span class="hero-orgs-label">Organizaciones miembro</span>
        <div class="hero-org-pills">
          <span class="org-pill" style="--c: var(--c-sur)">Estrellas del Sur · Córdoba</span>
          <span class="org-pill" style="--c: var(--c-magec)">Estrella Magec · Canarias</span>
          <span class="org-pill" style="--c: var(--c-murcia)">Murcia Debate · Murcia</span>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-scroll" aria-hidden="true">
    <div class="scroll-line"></div>
  </div>
</section>

<style>
.hero {
  position: relative; min-height: 100vh;
  background: linear-gradient(150deg, #1a0f00 0%, #291500 45%, #1e1200 100%);
  display: flex; align-items: center;
  overflow: hidden; padding: 6rem 0 5rem;
}

/* Grain texture overlay */
.hero::before {
  content: ''; position: absolute; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
  opacity: .04; pointer-events: none; z-index: 0;
}

.hero-bg-pattern {
  position: absolute; inset: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 80% 60% at 70% 50%, rgba(196,78,42,.14) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 90% 20%, rgba(217,167,39,.08) 0%, transparent 50%),
    radial-gradient(ellipse 30% 50% at 10% 80%, rgba(43,82,168,.1) 0%, transparent 50%);
  z-index: 0;
}

.hero-logo-bg {
  position: absolute; right: -5%; top: 50%;
  transform: translateY(-50%);
  width: clamp(300px, 42vw, 520px);
  opacity: .1; pointer-events: none; z-index: 0;
  filter: blur(1px);
}
.hero-logo-bg img { width: 100%; height: auto; }

.hero-inner { position: relative; z-index: 2; }
.hero-text { max-width: 640px; }

.hero-kicker {
  display: flex; align-items: center; gap: .5rem;
  margin-bottom: 1.75rem;
}
.kicker-dot {
  width: 8px; height: 8px; border-radius: 50%;
}
.kicker-label {
  font-size: .78rem; font-weight: 600; letter-spacing: .14em;
  text-transform: uppercase; color: rgba(255,255,255,.45);
  margin-left: .25rem;
}

.hero-text h1 {
  font-size: clamp(2.8rem, 5.5vw, 4.2rem);
  color: #fff; margin-bottom: 1.25rem; line-height: 1.08;
}
.hero-text h1 em {
  color: var(--c-magec); font-style: italic;
  display: block;
}

.hero-lead {
  font-size: clamp(1rem, 1.8vw, 1.12rem);
  color: rgba(255,255,255,.68); line-height: 1.75;
  margin-bottom: 2.5rem; max-width: 520px;
}

.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3.5rem; }

.hero-orgs { border-top: 1px solid rgba(255,255,255,.1); padding-top: 1.75rem; }
.hero-orgs-label {
  font-size: .72rem; font-weight: 600; letter-spacing: .1em;
  text-transform: uppercase; color: rgba(255,255,255,.35);
  display: block; margin-bottom: .75rem;
}
.hero-org-pills { display: flex; flex-wrap: wrap; gap: .5rem; }
.org-pill {
  font-size: .8rem; padding: .3rem .9rem;
  border-radius: var(--radius-full);
  background: rgba(255,255,255,.07);
  border: 1px solid var(--c);
  color: rgba(255,255,255,.7);
}

.hero-scroll {
  position: absolute; bottom: 2.5rem; left: 50%;
  transform: translateX(-50%);
}
.scroll-line {
  width: 1px; height: 48px;
  background: linear-gradient(to bottom, rgba(255,255,255,.0), rgba(255,255,255,.4));
  animation: scroll-grow 2s ease-in-out infinite;
  margin: auto;
}
@keyframes scroll-grow {
  0%   { transform: scaleY(0); transform-origin: top; opacity: 0; }
  50%  { transform: scaleY(1); transform-origin: top; opacity: 1; }
  100% { transform: scaleY(1); transform-origin: bottom; opacity: 0; }
}

@media (max-width: 768px) {
  .hero { min-height: auto; padding: 8rem 0 5rem; }
  .hero-logo-bg { opacity: .06; right: -10%; }
}
</style>

---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="hero">
  <canvas id="star-canvas" aria-hidden="true"></canvas>

  <div class="hero-eu-circle" aria-hidden="true">
    <svg viewBox="0 0 300 300" fill="none" xmlns="http://www.w3.org/2000/svg">
      {[0,30,60,90,120,150,180,210,240,270,300,330].map((deg, i) => {
        const rad = (deg - 90) * Math.PI / 180;
        const cx = 150 + 110 * Math.cos(rad);
        const cy = 150 + 110 * Math.sin(rad);
        return (
          <g transform={`translate(${cx},${cy})`} style={`animation-delay: ${i * 0.15}s`} class="eu-star">
            <polygon
              points="0,-12 2.6,-4.1 11,-4.1 4.4,1.6 6.9,9.8 0,5 -6.9,9.8 -4.4,1.6 -11,-4.1 -2.6,-4.1"
              fill="#ffcc00"
            />
          </g>
        );
      })}
    </svg>
  </div>

  <div class="container hero-content">
    <div class="hero-text fade-in">
      <div class="badge badge-eu">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
        Federación Española · Erasmus+
      </div>

      <h1>
        Conectando jóvenes<br />
        <em>a través de Europa</em>
      </h1>

      <p class="hero-lead">
        Federación Estrellas de Europa agrupa asociaciones juveniles de toda España
        para impulsar la movilidad, el aprendizaje no formal y los valores europeos.
      </p>

      <div class="hero-actions">
        <a href={`${base}/organizaciones/`} class="btn btn-gold btn-lg">
          Nuestras organizaciones
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={`${base}/sobre-nosotros/`} class="btn btn-outline-white btn-lg">
          Conocer la federación
        </a>
      </div>

      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">3</span>
          <span class="stat-lbl">Organizaciones</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat">
          <span class="stat-num">3</span>
          <span class="stat-lbl">Comunidades Autónomas</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat">
          <span class="stat-num">Erasmus<span style="font-size:.7em">+</span></span>
          <span class="stat-lbl">Programa europeo</span>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-scroll-hint" aria-hidden="true">
    <div class="scroll-mouse"></div>
  </div>
</section>

<style>
.hero {
  position: relative; min-height: 100vh;
  background: linear-gradient(135deg, #000d3d 0%, #001a6e 40%, var(--eu-blue) 70%, #0a2480 100%);
  display: flex; align-items: center;
  overflow: hidden; padding: 5rem 0 4rem;
}
#star-canvas {
  position: absolute; inset: 0; width: 100%; height: 100%;
  pointer-events: none; opacity: .6;
}
.hero-eu-circle {
  position: absolute; right: -60px; top: 50%;
  transform: translateY(-50%);
  width: clamp(340px, 45vw, 560px);
  opacity: .18; pointer-events: none;
}
.eu-star { animation: star-pulse 3s ease-in-out infinite alternate; }
@keyframes star-pulse {
  from { opacity: .6; transform: scale(.9); }
  to   { opacity: 1;  transform: scale(1.1); }
}
.hero-content { position: relative; z-index: 2; }
.hero-text { max-width: 620px; }
.badge { margin-bottom: 1.5rem; }
.hero-text h1 {
  font-size: clamp(2.4rem, 5vw, 3.8rem);
  color: #fff; margin-bottom: 1.25rem; line-height: 1.1;
}
.hero-text h1 em { color: var(--eu-gold); font-style: italic; }
.hero-lead {
  font-size: clamp(1rem, 1.8vw, 1.15rem);
  color: rgba(255,255,255,.75); line-height: 1.7;
  margin-bottom: 2rem;
}
.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3rem; }
.hero-stats {
  display: flex; align-items: center; gap: 1.5rem;
  flex-wrap: wrap;
}
.stat { display: flex; flex-direction: column; }
.stat-num {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1.8rem; font-weight: 700; color: var(--eu-gold); line-height: 1;
}
.stat-lbl { font-size: .78rem; color: rgba(255,255,255,.5); margin-top: .2rem; }
.stat-sep { width: 1px; height: 36px; background: rgba(255,255,255,.15); }
.hero-scroll-hint {
  position: absolute; bottom: 2rem; left: 50%;
  transform: translateX(-50%);
}
.scroll-mouse {
  width: 24px; height: 38px;
  border: 2px solid rgba(255,255,255,.3); border-radius: 12px;
  position: relative;
}
.scroll-mouse::after {
  content: ''; position: absolute;
  left: 50%; top: 6px; transform: translateX(-50%);
  width: 4px; height: 8px;
  background: rgba(255,255,255,.5); border-radius: 2px;
  animation: scroll-dot 1.8s ease-in-out infinite;
}
@keyframes scroll-dot {
  0%   { opacity: 1; transform: translateX(-50%) translateY(0); }
  100% { opacity: 0; transform: translateX(-50%) translateY(12px); }
}

@media (max-width: 768px) {
  .hero-eu-circle { display: none; }
  .hero { min-height: auto; padding: 7rem 0 5rem; }
}
</style>

<script>
// Starfield canvas
const canvas = document.getElementById('star-canvas') as HTMLCanvasElement;
if (canvas) {
  const ctx = canvas.getContext('2d')!;
  let W = 0, H = 0, stars: { x:number; y:number; r:number; alpha:number; speed:number; phase:number }[] = [];
  let animId = 0;
  let active = true;

  function resize() {
    W = canvas.width  = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
    stars = Array.from({ length: 140 }, () => ({
      x: Math.random() * W, y: Math.random() * H,
      r: Math.random() * 1.4 + 0.3,
      alpha: Math.random(),
      speed: Math.random() * 0.004 + 0.002,
      phase: Math.random() * Math.PI * 2,
    }));
  }

  function draw(t: number) {
    ctx.clearRect(0, 0, W, H);
    for (const s of stars) {
      s.alpha = 0.3 + 0.7 * (0.5 + 0.5 * Math.sin(t * s.speed * 1000 + s.phase));
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,255,255,${s.alpha})`;
      ctx.fill();
    }
    if (active) animId = requestAnimationFrame(draw);
  }

  const io = new IntersectionObserver(([e]) => {
    active = e.isIntersecting;
    if (active) animId = requestAnimationFrame(draw);
    else cancelAnimationFrame(animId);
  });

  window.addEventListener('resize', resize);
  io.observe(canvas);
  resize();
  animId = requestAnimationFrame(draw);
}
</script>

---
// EUBanner.astro — banda de cofinanciación de la Unión Europea (emblema oficial)
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="eu-banner">
  <div class="container eu-banner-inner">
    <img
      class="eu-emblem"
      src={`${base}/eu-cofinanciado.png`}
      alt="Cofinanciado por la Unión Europea"
      width="1000"
      height="210"
      loading="lazy"
      decoding="async"
    />
    <div class="eu-text">
      <p class="eu-programs">Erasmus+ · Cuerpo Europeo de Solidaridad</p>
      <p class="eu-disclaimer">
        Las opiniones y puntos de vista expresados son responsabilidad exclusiva de Estrellas de Europa
        y sus organizaciones miembro, y no reflejan necesariamente la posición de la Unión Europea ni de
        la Agencia Nacional Erasmus+.
      </p>
    </div>
  </div>
</div>

<style>
  .eu-banner {
    background: var(--parchment);
    border-top: 1px solid var(--sand-dark);
    padding: 1.75rem 0;
  }
  .eu-banner-inner { display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; }
  .eu-emblem { height: 52px; width: auto; flex-shrink: 0; }
  .eu-text { flex: 1; min-width: 240px; }
  .eu-programs { font-size: .82rem; font-weight: 600; color: var(--eu-blue); margin-bottom: .25rem; }
  .eu-disclaimer { font-size: .78rem; color: var(--ink-soft); line-height: 1.55; max-width: 640px; }

  @media (max-width: 640px) { .eu-banner-inner { gap: 1rem; } }
</style>

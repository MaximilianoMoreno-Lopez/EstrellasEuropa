---
// EUBanner.astro — banda de cofinanciación de la Unión Europea
---

<div class="eu-banner">
  <div class="container eu-banner-inner">
    <div class="eu-stars" aria-hidden="true">
      {Array.from({ length: 12 }).map((_, i) => (
        <span class="eu-star" style={`transform: rotate(${i * 30}deg) translateY(-18px);`}>★</span>
      ))}
    </div>

    <div class="eu-text">
      <p class="eu-label">Cofinanciado por la Unión Europea</p>
      <p class="eu-programs">
        <span>Erasmus+</span>
        <span class="sep" aria-hidden="true">·</span>
        <span>Cuerpo Europeo de Solidaridad</span>
      </p>
    </div>

    <div class="eu-disclaimer">
      <p>
        Las opiniones y puntos de vista expresados son responsabilidad exclusiva de Estrellas de Europa
        y sus organizaciones miembro, y no reflejan necesariamente la posición de la Unión Europea ni de
        la Agencia Nacional Erasmus+.
      </p>
    </div>
  </div>
</div>

<style>
  .eu-banner {
    background: linear-gradient(135deg, #002a8a 0%, #003399 55%, #0040bf 100%);
    padding: 1.5rem 0;
  }
  .eu-banner-inner { display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; }

  .eu-stars { position: relative; width: 54px; height: 54px; flex-shrink: 0; }
  .eu-star {
    position: absolute; top: 50%; left: 50%;
    font-size: .55rem; color: var(--eu-gold, #ffcc00);
    margin-top: -6px; margin-left: -4px;
    transform-origin: center center;
  }

  .eu-text { flex: 1; min-width: 200px; }
  .eu-label {
    font-size: .8rem; font-weight: 600; letter-spacing: .08em;
    text-transform: uppercase; color: rgba(255,255,255,.65); margin-bottom: .2rem;
  }
  .eu-programs {
    display: flex; align-items: center; gap: .5rem;
    color: #fff; font-weight: 600; font-size: 1rem;
  }
  .sep { color: rgba(255,255,255,.45); }

  .eu-disclaimer { max-width: 440px; }
  .eu-disclaimer p { font-size: .76rem; color: rgba(255,255,255,.5); line-height: 1.55; }

  @media (max-width: 640px) {
    .eu-banner-inner { gap: 1.25rem; }
    .eu-disclaimer { display: none; }
  }
</style>

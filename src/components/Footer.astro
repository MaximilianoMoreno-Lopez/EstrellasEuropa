---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">

      <div class="footer-brand">
        <a href={`${base}/`} class="footer-logo">
          <img src={`${base}/logo.jpg`} alt="Estrellas de Europa" width="36" height="36" />
          <span>Estrellas de Europa</span>
        </a>
        <p class="footer-desc">
          Federación que agrupa asociaciones juveniles comprometidas con la movilidad europea
          y el aprendizaje no formal.
        </p>
        <p class="footer-nif">NIF: G75822320</p>
      </div>

      <div class="footer-col">
        <h4>Organización</h4>
        <ul>
          <li><a href={`${base}/sobre-nosotros/`}>Sobre Nosotros</a></li>
          <li><a href={`${base}/organizaciones/`}>Organizaciones miembro</a></li>
          <li><a href={`${base}/contacto/`}>Contacto</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Miembros</h4>
        <ul>
          <li><a href="https://estrellasdelsur.eu" target="_blank" rel="noopener">Estrellas del Sur</a></li>
          <li>Estrella Magec</li>
          <li>Murcia Debate</li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Contacto</h4>
        <ul>
          <li><a href="mailto:federacion@estrellasdelsur.eu">federacion@estrellasdelsur.eu</a></li>
          <li class="footer-addr">C.C. Los Azahares, Planta Alta 3A<br />28039 Madrid</li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <p>&copy; {year} Federación Estrellas de Europa. Todos los derechos reservados.</p>
      <span class="eu-tag">Proyectos cofinanciados por la UE · Erasmus+</span>
    </div>
  </div>
</footer>

<style>
.footer {
  background: var(--ink);
  color: rgba(243,236,221,.6);
  padding: 4rem 0 2rem;
}
.footer-grid {
  display: grid; grid-template-columns: 2fr 1fr 1fr 1.4fr;
  gap: 3rem; padding-bottom: 3rem;
  border-bottom: 1px solid rgba(243,236,221,.08);
}
.footer-logo {
  display: flex; align-items: center; gap: .7rem;
  text-decoration: none; color: var(--sand);
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1rem; font-weight: 700; margin-bottom: 1rem;
}
.footer-logo img { border-radius: 4px; }
.footer-desc { font-size: .88rem; line-height: 1.7; color: rgba(243,236,221,.5); margin-bottom: .5rem; }
.footer-nif  { font-size: .76rem; color: rgba(243,236,221,.25); }
.footer-col h4 {
  font-family: 'DM Sans', sans-serif; font-size: .76rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase;
  color: rgba(243,236,221,.3); margin-bottom: 1rem;
}
.footer-col ul { display: flex; flex-direction: column; gap: .55rem; }
.footer-col a {
  font-size: .9rem; color: rgba(243,236,221,.55);
  text-decoration: none; transition: color .2s;
}
.footer-col a:hover { color: var(--c-magec); }
.footer-col li:not(:has(a)) { font-size: .88rem; color: rgba(243,236,221,.35); }
.footer-addr { font-size: .84rem !important; line-height: 1.6; color: rgba(243,236,221,.4); }
.footer-bottom {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: 1.5rem; gap: 1rem; flex-wrap: wrap;
}
.footer-bottom p { font-size: .8rem; color: rgba(243,236,221,.28); }
.eu-tag { font-size: .76rem; color: rgba(243,236,221,.28); }

@media (max-width: 900px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; } }
@media (max-width: 560px) {
  .footer-grid { grid-template-columns: 1fr; gap: 1.5rem; }
  .footer-bottom { flex-direction: column; align-items: flex-start; }
}
</style>

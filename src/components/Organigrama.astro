---
const members = [
  { name: 'Maximiliano Moreno López', role: 'Presidente',             org: 'Estrellas del Sur', color: '#c44e2a', initials: 'MM', angle: -90 },
  { name: 'Pablo Sánchez Ruiz',       role: 'Vicepresidente',         org: 'Estrellas del Sur', color: '#c44e2a', initials: 'PS', angle: -18 },
  { name: 'Alejandro Artiles',        role: 'Gestión de proyectos',   org: 'Estrella Magec',    color: '#d9a727', initials: 'AA', angle: 54  },
  { name: 'Nacho Fenollar',           role: 'Participación juvenil',  org: 'Murcia Debate',     color: '#6b3a8a', initials: 'NF', angle: 126 },
  { name: 'Junta Directiva',          role: 'Órgano de gobierno',     org: 'Federación',        color: '#2b52a8', initials: 'JD', angle: 198 },
];

// SVG radial layout
const CX = 400; const CY = 340; const R = 210;
const nodes = members.map(m => {
  const rad = (m.angle * Math.PI) / 180;
  return { ...m, x: CX + R * Math.cos(rad), y: CY + R * Math.sin(rad) };
});
---

<section class="section-sm organigrama-section" id="equipo">
  <div class="container">
    <div class="org-header fade-in">
      <span class="section-label">Junta Directiva</span>
      <h2 class="section-title">Equipo de la federación</h2>
      <p class="section-subtitle">
        Representantes de las organizaciones miembro que gobiernan la federación
        con una visión plural e integrada.
      </p>
    </div>

    <div class="org-chart-wrap fade-in fade-in-delay-1">
      <svg
        viewBox="0 40 800 600"
        xmlns="http://www.w3.org/2000/svg"
        class="org-svg"
        aria-label="Organigrama radial de la federación"
      >
        <!-- Spokes -->
        {nodes.map(n => (
          <line
            x1={CX} y1={CY}
            x2={n.x} y2={n.y}
            stroke={n.color}
            stroke-width="2.5"
            stroke-opacity="0.5"
            stroke-dasharray="6 4"
          />
        ))}

        <!-- Outer node circles + labels -->
        {nodes.map(n => (
          <g class="org-node" transform={`translate(${n.x},${n.y})`}>
            <!-- Glow -->
            <circle r="38" fill={n.color} opacity=".1" />
            <!-- Ring -->
            <circle r="30" fill="var(--parchment)" stroke={n.color} stroke-width="2.5" />
            <!-- Initials -->
            <text
              x="0" y="5"
              text-anchor="middle"
              font-family="Playfair Display, Georgia, serif"
              font-size="13"
              font-weight="600"
              fill={n.color}
            >{n.initials}</text>
            <!-- Name label -->
            <text
              x="0" y={n.y < CY - 20 ? -44 : n.y > CY + 20 ? 52 : 0}
              text-anchor={n.x < CX - 20 ? 'end' : n.x > CX + 20 ? 'start' : 'middle'}
              dx={n.x < CX - 40 ? -10 : n.x > CX + 40 ? 10 : 0}
              dy={n.y < CY - 20 ? 0 : n.y > CY + 20 ? 0 : (n.x < CX ? 5 : 5)}
              font-family="DM Sans, system-ui, sans-serif"
              font-size="11.5"
              font-weight="600"
              fill="var(--ink)"
            >{n.name}</text>
            <text
              x="0" y={n.y < CY - 20 ? -30 : n.y > CY + 20 ? 67 : 18}
              text-anchor={n.x < CX - 20 ? 'end' : n.x > CX + 20 ? 'start' : 'middle'}
              dx={n.x < CX - 40 ? -10 : n.x > CX + 40 ? 10 : 0}
              font-family="DM Sans, system-ui, sans-serif"
              font-size="10"
              fill="var(--ink-mute)"
            >{n.role}</text>
          </g>
        ))}

        <!-- Central hub -->
        <circle cx={CX} cy={CY} r="56" fill="var(--sand)" stroke="var(--sand-deeper)" stroke-width="1.5" />
        <circle cx={CX} cy={CY} r="50" fill="var(--parchment)" stroke="var(--line)" stroke-width="1" />
        <text
          x={CX} y={CY - 6}
          text-anchor="middle"
          font-family="Playfair Display, Georgia, serif"
          font-size="14"
          font-style="italic"
          fill="var(--ink)"
        >Federación</text>
        <text
          x={CX} y={CY + 12}
          text-anchor="middle"
          font-family="DM Sans, system-ui, sans-serif"
          font-size="9.5"
          letter-spacing="1"
          fill="var(--ink-mute)"
        >ESTRELLAS DE EUROPA</text>
      </svg>

      <!-- Cards list (mobile + semantic) -->
      <div class="org-cards">
        {members.map(m => (
          <div class="org-card" style={`--c: ${m.color}`}>
            <div class="org-avatar">{m.initials}</div>
            <div class="org-info">
              <strong>{m.name}</strong>
              <span>{m.role}</span>
              <span class="org-org">{m.org}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
.organigrama-section { background: var(--sand); }
.org-header { max-width: 560px; margin-bottom: 3rem; }
.org-chart-wrap { display: flex; flex-direction: column; align-items: center; gap: 2rem; }

.org-svg {
  width: 100%; max-width: 680px;
  height: auto; display: block;
}
.org-node { cursor: default; }
.org-node circle { transition: r .2s; }
.org-node:hover circle:nth-child(2) { r: 34; }

.org-cards {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1rem; width: 100%;
}
.org-card {
  display: flex; align-items: center; gap: .85rem;
  background: var(--parchment);
  border-radius: var(--radius-md);
  border: 1px solid rgba(42,31,14,.08);
  border-left: 3px solid var(--c);
  padding: .9rem 1.1rem;
  box-shadow: var(--shadow-card);
}
.org-avatar {
  width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
  background: var(--c); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: .88rem;
}
.org-info { display: flex; flex-direction: column; gap: .1rem; }
.org-info strong { font-size: .9rem; color: var(--ink); line-height: 1.2; }
.org-info span   { font-size: .78rem; color: var(--ink-soft); }
.org-org { color: var(--c) !important; font-weight: 500; }

@media (max-width: 860px) { .org-cards { grid-template-columns: 1fr 1fr; } }
@media (max-width: 560px) {
  .org-cards { grid-template-columns: 1fr; }
  .org-svg { display: none; }
}
</style>

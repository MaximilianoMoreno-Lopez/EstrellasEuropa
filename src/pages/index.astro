---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import MisionSection from '../components/MisionSection.astro';
import ProyectosSection from '../components/ProyectosSection.astro';
import AccionLocal from '../components/AccionLocal.astro';
import MemberOrgs from '../components/MemberOrgs.astro';
import Organigrama from '../components/Organigrama.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const latest = (await getCollection('noticias'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);

const newsColor = {
  'Federación': 'var(--c-sur)',
  'Erasmus+': 'var(--eu-blue)',
  'Cooperación': 'var(--c-murcia)',
  'Acción local': 'var(--c-green)',
  'Participación': 'var(--c-magec)',
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Estrellas de Europa",
  "url": "https://estrellaseuropa.eu",
  "logo": "https://estrellaseuropa.eu/logo.jpg",
  "email": "federacion@estrellasdelsur.eu",
  "foundingDate": "2024",
  "description": "Federación de asociaciones juveniles españolas unidas por los valores europeos, la movilidad internacional y la participación activa.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "C.C. Los Azahares, Planta Alta 3A",
    "postalCode": "28039",
    "addressLocality": "Madrid",
    "addressCountry": "ES"
  },
  "legalName": "Federación Estrellas de Europa",
  "taxID": "G75822320",
  "areaServed": "España",
  "knowsAbout": ["Erasmus+", "movilidad juvenil", "voluntariado europeo", "asociaciones juveniles", "educación no formal"],
  "member": [
    { "@type": "Organization", "name": "Estrellas del Sur", "url": "https://estrellasdelsur.eu" },
    { "@type": "Organization", "name": "Estrella Magec" },
    { "@type": "Organization", "name": "Murcia Debate" }
  ]
};
---

<BaseLayout
  title="Inicio"
  description="Federación española de asociaciones juveniles unidas por los valores europeos. Impulsamos la movilidad Erasmus+, el voluntariado y la participación activa de la juventud."
  jsonLd={jsonLd}
>
  <Hero />
  <Stats />
  <MisionSection />
  <ProyectosSection />
  <AccionLocal />
  <MemberOrgs />

  <!-- Actualidad teaser -->
  <section class="section news-teaser">
    <div class="container">
      <div class="news-head fade-in">
        <div>
          <span class="section-label">Actualidad</span>
          <h2 class="section-title">Últimas novedades</h2>
        </div>
        <a href={`${base}/actualidad/`} class="news-all">Ver todo →</a>
      </div>
      <div class="news-grid">
        {latest.map((a, i) => (
          <a
            href={`${base}/actualidad/${a.slug}/`}
            class={`news-card fade-in fade-in-delay-${i + 1}`}
            style={`--ac: ${newsColor[a.data.type] ?? 'var(--c-blue)'}`}
          >
            <span class="news-type">{a.data.type}</span>
            <h3>{a.data.title}</h3>
            {a.data.description && <p>{a.data.description}</p>}
            <span class="news-read">Leer más →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Organigrama />

  <!-- CTA Strip -->
  <section class="cta-strip">
    <div class="container cta-inner">
      <div class="cta-text fade-in">
        <h2>¿Tu asociación quiere unirse?</h2>
        <p>Si compartes los valores europeos y trabajas con jóvenes, contáctanos para explorar una posible adhesión a la federación.</p>
      </div>
      <div class="cta-actions fade-in fade-in-delay-1">
        <a href={`${base}/unete/`} class="btn btn-amber btn-lg">Quiero unirme</a>
        <a href={`${base}/sobre-nosotros/`} class="btn btn-outline-white btn-lg">Saber más</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.cta-strip {
  background: linear-gradient(135deg, #001a6e 0%, var(--eu-blue) 60%, #0a2480 100%);
  padding: 5rem 0;
}
.cta-inner {
  display: flex; align-items: center; justify-content: space-between;
  gap: 3rem; flex-wrap: wrap;
}
.cta-text h2 {
  font-size: clamp(1.5rem, 3vw, 2rem);
  color: #fff; margin-bottom: .75rem;
}
.cta-text p { color: rgba(255,255,255,.7); max-width: 460px; line-height: 1.65; }
.cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; flex-shrink: 0; }

/* Actualidad teaser */
.news-teaser { background: var(--parchment); }
.news-head {
  display: flex; align-items: flex-end; justify-content: space-between;
  gap: 1rem; margin-bottom: 2.5rem; flex-wrap: wrap;
}
.news-all {
  font-size: .9rem; font-weight: 600; color: var(--c-sur);
  text-decoration: none; white-space: nowrap; transition: gap .2s;
}
.news-all:hover { text-decoration: underline; }
.news-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
.news-card {
  display: flex; flex-direction: column; gap: .6rem;
  background: var(--sand); border: 1px solid var(--sand-dark);
  border-top: 3px solid var(--ac);
  border-radius: var(--radius-md); padding: 1.5rem;
  text-decoration: none; color: inherit;
  transition: transform .25s ease, box-shadow .25s ease;
}
.news-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-card); }
.news-type {
  font-size: .7rem; font-weight: 700; letter-spacing: .1em;
  text-transform: uppercase; color: var(--ac);
}
.news-card h3 {
  font-family: 'Playfair Display Variable', 'Playfair Display', Georgia, serif;
  font-size: 1.12rem; color: var(--ink); line-height: 1.3;
}
.news-card p {
  font-size: .87rem; color: var(--ink-soft); line-height: 1.6; flex: 1;
  display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
}
.news-read { font-size: .82rem; font-weight: 600; color: var(--ac); margin-top: .25rem; }

@media (max-width: 768px) {
  .cta-inner { flex-direction: column; }
  .news-grid { grid-template-columns: 1fr; }
}
</style>

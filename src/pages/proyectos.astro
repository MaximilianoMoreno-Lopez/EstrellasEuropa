---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const proyectos = [
  {
    badge: 'Erasmus+ KA153',
    accent: 'var(--eu-blue)',
    title: 'Movilidad de Trabajadores de Juventud',
    status: 'Activo',
    statusColor: 'var(--c-green)',
    icon: '🏆',
    lead: 'Subvención Erasmus+ KA153 concedida a la federación para financiar estancias formativas de nuestros educadores y técnicos de juventud en organizaciones europeas.',
    points: [
      'Estancias formativas para youth workers en organizaciones de acogida europeas.',
      'Transferencia de buenas prácticas y metodologías de educación no formal.',
      'Mejora directa de la calidad de los proyectos que después realizamos en España.',
    ],
    tags: ['Movilidad internacional', 'Formación', 'Trabajadores de juventud'],
  },
  {
    badge: 'Cooperación europea',
    accent: 'var(--c-murcia)',
    title: 'NEST',
    status: 'En desarrollo',
    statusColor: 'var(--c-magec)',
    icon: '🌐',
    lead: 'Proyecto de cooperación internacional junto a socios de distintos países europeos, centrado en la educación no formal, la participación juvenil y el intercambio de metodologías innovadoras.',
    points: [
      'Trabajo en red con organizaciones juveniles de varios países.',
      'Creación de recursos y herramientas compartidas.',
      'Innovación en las formas de conectar a la juventud con Europa.',
    ],
    tags: ['Cooperación internacional', 'Educación no formal', 'Innovación'],
  },
];

const acciones = [
  { code: 'KA1', name: 'Movilidad de las personas', desc: 'Intercambios juveniles, movilidad de trabajadores de juventud (KA151/KA153) y actividades de participación.' },
  { code: 'KA2', name: 'Cooperación entre organizaciones', desc: 'Asociaciones de cooperación (KA210/KA220) para crear e intercambiar prácticas innovadoras entre entidades europeas.' },
  { code: 'CES', name: 'Cuerpo Europeo de Solidaridad', desc: 'Voluntariado y proyectos de solidaridad que permiten a la juventud contribuir en su comunidad y en Europa.' },
];
---

<BaseLayout
  title="Proyectos"
  description="Proyectos europeos de la Federación Estrellas de Europa: movilidad Erasmus+ KA153 y el proyecto de cooperación NEST."
>
  <div class="page-hero">
    <div class="container page-hero-content">
      <span class="badge badge-eu fade-in">Proyectos europeos</span>
      <h1 class="fade-in fade-in-delay-1">Lo que estamos construyendo</h1>
      <p class="fade-in fade-in-delay-2">
        Proyectos con impacto real para jóvenes y educadores de toda España,
        financiados por el programa Erasmus+ de la Unión Europea.
      </p>
    </div>
  </div>

  <section class="section">
    <div class="container proyectos-list">
      {proyectos.map((p) => (
        <article class="proyecto fade-in" style={`--ac: ${p.accent}`}>
          <div class="proyecto-side">
            <span class="proyecto-icon">{p.icon}</span>
            <span class="proyecto-badge">{p.badge}</span>
            <span class="proyecto-status" style={`color:${p.statusColor}`}>
              <span class="status-dot" style={`background:${p.statusColor}`}></span>{p.status}
            </span>
          </div>
          <div class="proyecto-main">
            <h2>{p.title}</h2>
            <p class="proyecto-lead">{p.lead}</p>
            <ul class="proyecto-points">
              {p.points.map((pt) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                  {pt}
                </li>
              ))}
            </ul>
            <div class="proyecto-tags">
              {p.tags.map((t) => <span class="proyecto-tag">{t}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section acciones-section">
    <div class="container">
      <div class="acciones-header fade-in">
        <span class="section-label">El programa Erasmus+</span>
        <h2 class="section-title">Cómo financia Europa el trabajo juvenil</h2>
        <p class="section-subtitle">
          Nuestros proyectos se enmarcan en las distintas acciones del programa Erasmus+
          y del Cuerpo Europeo de Solidaridad.
        </p>
      </div>
      <div class="acciones-grid">
        {acciones.map((a, i) => (
          <div class={`accion-card fade-in fade-in-delay-${i + 1}`}>
            <span class="accion-code">{a.code}</span>
            <h3>{a.name}</h3>
            <p>{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="proyectos-cta">
    <div class="container cta-inner">
      <div class="fade-in">
        <h2>¿Quieres participar en un proyecto?</h2>
        <p>Sigue nuestra actualidad o escríbenos para conocer las próximas convocatorias.</p>
      </div>
      <div class="cta-actions fade-in fade-in-delay-1">
        <a href={`${base}/actualidad/`} class="btn btn-amber btn-lg">Ver actualidad</a>
        <a href={`${base}/contacto/`} class="btn btn-outline-white btn-lg">Contactar</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .proyectos-list { display: flex; flex-direction: column; gap: 2.5rem; }
  .proyecto {
    display: grid; grid-template-columns: 240px 1fr;
    background: var(--parchment);
    border: 1px solid rgba(42,31,14,.08);
    border-left: 4px solid var(--ac);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition: box-shadow .25s;
  }
  .proyecto:hover { box-shadow: var(--shadow-lg); }
  .proyecto-side {
    background: color-mix(in srgb, var(--ac) 8%, var(--sand));
    border-right: 1px solid rgba(42,31,14,.06);
    padding: 2rem 1.5rem;
    display: flex; flex-direction: column; gap: .85rem; align-items: flex-start;
  }
  .proyecto-icon { font-size: 2.5rem; line-height: 1; }
  .proyecto-badge {
    font-size: .72rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    color: #fff; background: var(--ac); padding: .3rem .8rem; border-radius: var(--radius-full);
  }
  .proyecto-status { display: flex; align-items: center; gap: .4rem; font-size: .82rem; font-weight: 600; }
  .status-dot { width: 7px; height: 7px; border-radius: 50%; }
  .proyecto-main { padding: 2rem 2.25rem; }
  .proyecto-main h2 { font-size: 1.5rem; color: var(--ink); margin-bottom: .6rem; }
  .proyecto-lead { color: var(--ink-soft); line-height: 1.7; margin-bottom: 1.25rem; }
  .proyecto-points { display: flex; flex-direction: column; gap: .55rem; margin-bottom: 1.25rem; }
  .proyecto-points li {
    display: flex; align-items: flex-start; gap: .55rem;
    font-size: .92rem; color: var(--ink-soft); line-height: 1.5;
  }
  .proyecto-points svg { color: var(--ac); flex-shrink: 0; margin-top: .15rem; }
  .proyecto-tags { display: flex; flex-wrap: wrap; gap: .4rem; }
  .proyecto-tag {
    font-size: .72rem; font-weight: 500; padding: .25rem .7rem;
    border-radius: var(--radius-full); background: var(--sand);
    color: var(--ink-soft); border: 1px solid var(--sand-dark);
  }

  .acciones-section { background: var(--parchment); }
  .acciones-header { max-width: 600px; margin-bottom: 2.5rem; }
  .acciones-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .accion-card {
    background: var(--sand); border: 1px solid var(--sand-dark);
    border-radius: var(--radius-md); padding: 1.75rem;
  }
  .accion-code {
    display: inline-block; font-family: 'Playfair Display Variable', serif;
    font-size: 1.5rem; font-weight: 700; color: var(--eu-blue); margin-bottom: .5rem;
  }
  .accion-card h3 { font-size: 1.05rem; color: var(--ink); margin-bottom: .4rem; font-family: 'DM Sans Variable', sans-serif; font-weight: 600; }
  .accion-card p { font-size: .88rem; color: var(--ink-soft); line-height: 1.6; }

  .proyectos-cta {
    background: linear-gradient(135deg, #001a6e 0%, var(--eu-blue) 60%, #0a2480 100%);
    padding: 4rem 0;
  }
  .cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2.5rem; flex-wrap: wrap; }
  .cta-inner h2 { color: #fff; font-size: clamp(1.4rem, 2.6vw, 1.9rem); margin-bottom: .5rem; }
  .cta-inner p { color: rgba(255,255,255,.72); max-width: 440px; }
  .cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  @media (max-width: 760px) {
    .proyecto { grid-template-columns: 1fr; }
    .proyecto-side { flex-direction: row; align-items: center; border-right: none; border-bottom: 1px solid rgba(42,31,14,.06); flex-wrap: wrap; }
    .proyecto-icon { font-size: 2rem; }
    .acciones-grid { grid-template-columns: 1fr; }
  }
</style>

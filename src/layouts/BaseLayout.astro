---
import '@fontsource-variable/dm-sans';
import '@fontsource-variable/playfair-display';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import EUBanner from '../components/EUBanner.astro';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogImage?: string;
  ogType?: string;
  publishedTime?: string;
  jsonLd?: object;
  breadcrumbs?: { name: string; url: string }[];
}

const {
  title,
  description = 'Federación de asociaciones juveniles españolas unidas por los valores europeos. Erasmus+, movilidad internacional y participación activa.',
  ogTitle,
  ogImage = '/og-image.png',
  ogType = 'website',
  publishedTime,
  jsonLd,
  breadcrumbs,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const pageTitle = title === 'Inicio'
  ? 'Estrellas de Europa | Federación de Asociaciones Juveniles'
  : `${title} | Estrellas de Europa`;

const socialTitle = ogTitle ?? (title === 'Inicio' ? 'Estrellas de Europa' : pageTitle);

const siteURL = 'https://estrellaseuropa.eu';
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const ogImageURL = `${siteURL}${ogImage}`;

// BreadcrumbList JSON-LD (cuando la página aporta migas)
const breadcrumbJsonLd = breadcrumbs && breadcrumbs.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
        item: `${siteURL}${b.url}`,
      })),
    }
  : null;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="theme-color" content="#001a6e" />

  <!-- SEO -->
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />

  <!-- Open Graph -->
  <meta property="og:type"         content={ogType} />
  <meta property="og:url"          content={canonicalURL} />
  <meta property="og:title"        content={socialTitle} />
  <meta property="og:description"  content={description} />
  <meta property="og:image"        content={ogImageURL} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name"    content="Estrellas de Europa" />
  <meta property="og:locale"       content="es_ES" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={socialTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageURL} />

  <!-- JSON-LD -->
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  {breadcrumbJsonLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />}

  <!-- Favicon e iconos -->
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon-32x32.png`} />
  <link rel="apple-touch-icon" sizes="180x180" href={`${base}/apple-touch-icon.png`} />
  <link rel="manifest" href={`${base}/site.webmanifest`} />

  <!-- Fuentes: self-hosted via @fontsource-variable (importadas arriba) -->
</head>
<body>
  <a href="#main" class="skip-link">Saltar al contenido</a>
  <Navbar />
  <main id="main">
    <slot />
  </main>
  <EUBanner />
  <Footer />

  <script>
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.12 }
    );
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
  </script>
</body>
</html>
